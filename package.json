{
  "name": "mimo-cli",
  "version": "0.1.0",
  "description": "A terminal AI coding assistant powered by MiMo, inspired by Claude Code",
  "type": "module",
  "bin": {
    "mimo": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mimo": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "ai",
    "mimo",
    "coding-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "ink": "^4.4.1",
    "openai": "^4.104.0",
    "ora": "^7.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
