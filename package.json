{
  "name": "mimo-cli",
  "version": "2.0.0",
  "description": "MiMo CLI - AI 编程助手，接入小米 MiMo 大模型 (Claude Code 风格)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mimo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ai",
    "mimo",
    "coding-assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.31",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "simple-git": "^3.36.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0"
  }
}
